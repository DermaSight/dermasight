ENVIRONMENT="development"

# GENERAL SETTINGS
HOST="127.0.0.1"
PORT=5000
API_PREFIX="/api"

# COOKIE RELATED SETTINGS
COOKIE_SECRET="your-cookie-secret-here"

# DATABASE SETTINGS
DB_HOST="127.0.0.1"
DB_PORT=5432
DB_USER="dermasight"
DB_PASSWORD="your-db-password-here"
DB_NAME="dermasight_db"

# PASETO TOKEN SETTINGS
# Secret Key format: k4.local.{32-byte-hex-string}
PASETO_SECRET_KEY="your-paseto-secret-key-here"

# SMTP / CONTACT FORM SETTINGS
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="your-smtp-user@example.com"
SMTP_PASS="your-smtp-password"
CONTACT_EMAIL="admin@dermasight.com,team@dermasight.com"
CONTACT_FROM_EMAIL=""

# SUPER ADMIN SEED
SUPER_ADMIN_EMAIL="admin@dermasight.com"
SUPER_ADMIN_PASSWORD="your-super-admin-password"
SUPER_ADMIN_NAME="Super Admin"

# CORS SETTINGS
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

# ML MODEL API SETTINGS
MODEL_API_URL="http://localhost:8000"

# CLOUDFLARE R2 SETTINGS
R2_STORAGE_URL="https://your-account-id.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="dermasight"
R2_REGION="auto"
