# ─── DermaSight v3 — Environment Variables ────────────────────────────────────
# Copy file ini → .env lalu isi nilainya.
# JANGAN commit .env ke repository.

# ── Groq API ──────────────────────────────────────────────────────────────────
# Daftar gratis & ambil key di: https://console.groq.com/keys
GROQ_API_KEY=

# Model yang digunakan (opsional — default: llama-3.3-70b-versatile)
# Pilihan lain yang tersedia di Groq free tier:
#   llama-3.1-8b-instant     → lebih cepat, lebih ringan
#   llama-3.3-70b-versatile  → lebih pintar (default)
GROQ_MODEL=llama-3.3-70b-versatile
